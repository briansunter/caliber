# Calibre source (the default is ~/Calibre Library/metadata.db)
CALIBRE_LIBRARY_PATH=/path/to/Calibre Library
CALIBRE_DB_NAME=metadata.db

# Server and writable Caliber cache/config
CALIBER_HOST=127.0.0.1
PORT=3003
# CALIBER_CONFIG_DIR=/path/to/caliber-config
CALIBER_DB_REFRESH_INTERVAL_MS=60000

# Reverse-proxy and cookie settings
# CALIBER_BASE_URL=https://books.example.test
CALIBER_TRUST_PROXY=false
CALIBER_COOKIE_SECURE=true

# Optional integrations
CALIBER_MCP_ENABLED=false
# CALIBER_USER_DB_PATH=/path/to/users.db

# Optional Poppler paths for PDF page streaming
# PDFINFO_PATH=/opt/homebrew/bin/pdfinfo
# PDFTOPPM_PATH=/opt/homebrew/bin/pdftoppm
